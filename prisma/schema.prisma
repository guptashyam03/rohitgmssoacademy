generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum PlanType {
  PDF_ONLY
  MOCK_TEST_ONLY
  PREMIUM
  CUSTOM
}

enum ContentType {
  PDF
  VIDEO
  MOCK_TEST
  BUNDLE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            Role      @default(STUDENT)
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  orders          Order[]
  accessGrants    AccessGrant[]
  testAttempts    TestAttempt[]
  wishlist        WishlistItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  type        PlanType
  description String?
  price       Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  accessGrants AccessGrant[]
  contents     PlanContent[]
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        ContentType
  subject     String?
  tags        String[]
  thumbnail   String?
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // PDF fields
  driveFileId   String?
  driveShareUrl String?
  previewPages  Int?

  // Video fields
  youtubeId    String?
  youtubUrl    String?
  duration     String?

  // Mock Test fields
  mockTest     MockTest?

  plans        PlanContent[]
  wishlistItems WishlistItem[]
}

model PlanContent {
  planId    String
  contentId String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([planId, contentId])
}

model MockTest {
  id               String    @id @default(cuid())
  contentId        String    @unique
  duration         Int       // minutes
  totalMarks       Int
  passMark         Int
  negativeMarks    Float     @default(0)
  marksPerQuestion Float     @default(1)
  instructions     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  content   Content      @relation(fields: [contentId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  TestAttempt[]
}

model Question {
  id           String   @id @default(cuid())
  mockTestId   String
  question     String   @db.Text
  options      Json     // ["A", "B", "C", "D"]
  correctAnswer String
  explanation  String?  @db.Text
  marks        Int      @default(1)
  order        Int      @default(0)
  section      String   @default("General")
  createdAt    DateTime @default(now())

  mockTest MockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
}

model TestAttempt {
  id          String    @id @default(cuid())
  userId      String
  mockTestId  String
  answers     Json      // { questionId: selectedAnswer }
  score       Float
  totalMarks  Int
  passed      Boolean
  timeTaken   Int       // seconds
  submittedAt DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockTest MockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  planId          String
  amount          Float
  currency        String      @default("INR")
  status          OrderStatus @default(PENDING)
  razorpayOrderId String?     @unique
  razorpayPaymentId String?
  razorpaySignature String?
  couponId        String?
  discountAmount  Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   Plan    @relation(fields: [planId], references: [id])
  coupon Coupon? @relation(fields: [couponId], references: [id])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float    // percentage or flat
  isPercent   Boolean  @default(true)
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model AccessGrant {
  id        String    @id @default(cuid())
  userId    String
  planId    String
  grantedBy String?   // admin user id
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}
